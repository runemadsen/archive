{
  "name": "gemme-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Gemme is a self-hosted, search-first archive for all your files",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "format": "prettier --write \"packages/**/*.js\"",
    "format:check": "prettier --check \"packages/**/*.js\"",
    "lint": "eslint .",
    "gemme": "node --no-warnings packages/cli/bin/gemme.js",
    "dev:init": "node --no-warnings packages/cli/bin/gemme.js init --data-dir ./dev-instance --no-install",
    "dev:user": "node --no-warnings packages/cli/bin/gemme.js create-user --email dev@example.com --password dev --data-dir ./dev-instance",
    "dev": "node --no-warnings packages/cli/bin/gemme.js start --data-dir ./dev-instance --dev"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.6"
  }
}
